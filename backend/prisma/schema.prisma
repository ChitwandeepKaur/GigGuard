generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String                    @id @default(uuid())
  email           String                    @unique
  password_hash   String?
  created_at      DateTime                  @default(now())
  updated_at      DateTime                  @updatedAt
  expense_log     ExpenseEntry[]
  expenses        ExpenseProfile?
  income_log      IncomeEntry[]
  insurance       InsurancePolicy?
  recommendations InsuranceRecommendation[]
  profile         UserProfile?
}

model UserProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  gig_types        String[] @default([])
  income_frequency String   @default("weekly")
  weekly_low       Float    @default(0)
  weekly_high      Float    @default(0)
  worst_week       Float    @default(0)
  best_week        Float    @default(0)
  floor_income     Float    @default(0)
  average_income   Float    @default(0)
  volatility_score Float    @default(0)
  available_cash   Float    @default(0)
  current_buffer   Float    @default(0)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
}

model ExpenseProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  rent            Float    @default(0)
  utilities       Float    @default(0)
  debt_minimums   Float    @default(0)
  transport       Float    @default(0)
  groceries       Float    @default(0)
  insurance_cost  Float    @default(0)
  phone           Float    @default(0)
  subscriptions   Float    @default(0)
  eating_out      Float    @default(0)
  shopping        Float    @default(0)
  entertainment   Float    @default(0)
  survival_number Float    @default(0)
  paid_categories String[] @default([])
  last_paid_reset DateTime @default(now())
  updated_at      DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model IncomeEntry {
  id         String   @id @default(uuid())
  userId     String
  amount     Float
  week_of    DateTime
  source     String
  note       String?
  created_at DateTime @default(now())
  date       DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model ExpenseEntry {
  id         String   @id @default(uuid())
  userId     String
  amount     Float
  date       DateTime @default(now())
  category   String
  note       String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model InsurancePolicy {
  id              String    @id @default(uuid())
  userId          String    @unique
  file_name       String
  file_url        String
  extracted_text  String?
  covered         String[]  @default([])
  not_covered     String[]  @default([])
  deductible      String?
  limits          String?
  renewal_date    String?
  quiz_questions  Json?
  last_quiz_score Int?
  last_quiz_date  DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
}

model InsuranceRecommendation {
  id              String   @id @default(uuid())
  userId          String
  product         String
  reason          String
  priority        String
  gap_description String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}
